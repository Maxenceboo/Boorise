{
  "name": "boorise",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k --names BACK,FRONT --prefix-colors magenta.bold,cyan.bold \"npm run convex:dev\" \"npm run frontend:dev\"",
    "frontend:dev": "npm --prefix frontend run dev",
    "convex:dev": "convex dev",
    "convex:deploy": "convex deploy",
    "convex:codegen": "convex codegen",
    "convex:ai-files": "convex ai-files install",
    "test:calc": "tsx --test tests/materialCalculation.test.ts"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "convex": "^1.31.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@auth/core": "^0.41.1",
    "@convex-dev/auth": "^0.0.94"
  }
}
